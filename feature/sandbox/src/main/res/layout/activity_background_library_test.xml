<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:ignore="MissingPrefix">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/background_library_test_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/background_library_section_basic"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/background_library_sample_rounded_solid"
            app:bl_corners_radius="12dp"
            app:bl_shape="rectangle"
            app:bl_solid_color="@color/teal_200"
            app:bl_stroke_color="@color/teal_700"
            app:bl_stroke_width="1dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/background_library_section_gradient"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:minHeight="56dp"
            android:padding="12dp"
            android:text="@string/background_library_sample_gradient"
            android:textColor="@color/white"
            app:bl_corners_radius="8dp"
            app:bl_gradient_angle="0"
            app:bl_gradient_endColor="@color/purple_700"
            app:bl_gradient_startColor="@color/purple_500"
            app:bl_shape="rectangle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/background_library_section_pressed"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="48dp"
            android:padding="12dp"
            android:text="@string/background_library_sample_pressed"
            app:bl_pressed_solid_color="@color/purple_200"
            app:bl_shape="rectangle"
            app:bl_unPressed_solid_color="@color/purple_500" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/background_library_section_ripple"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="48dp"
            android:padding="12dp"
            android:text="@string/background_library_sample_ripple"
            app:bl_corners_radius="24dp"
            app:bl_ripple_color="#40000000"
            app:bl_ripple_enable="true"
            app:bl_shape="rectangle"
            app:bl_solid_color="@color/teal_700" />
    </LinearLayout>
</ScrollView>
