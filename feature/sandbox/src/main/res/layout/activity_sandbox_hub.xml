<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/sandbox_hub_title"
        android:textAppearance="?android:attr/textAppearanceLarge" />

    <Button
        android:id="@+id/btn_open_background_library_test"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/sandbox_open_background" />

    <Button
        android:id="@+id/btn_open_module_adapter_test"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/sandbox_open_module_adapter" />

    <Button
        android:id="@+id/btn_open_page_state_test"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/sandbox_open_page_state" />

    <Button
        android:id="@+id/btn_open_storage_adapt_test"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sandbox_open_storage_adapt" />
</LinearLayout>
