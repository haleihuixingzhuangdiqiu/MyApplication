<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sandbox_vm_test_section_events"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_vm_show_toast"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/sandbox_vm_test_btn_toast" />

            <Button
                android:id="@+id/btn_vm_post_error"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/sandbox_vm_test_btn_error" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_vm_emit_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_message" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/sandbox_vm_test_section_loading"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <ProgressBar
            android:id="@+id/progress_inline_loading"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_inline_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <Button
            android:id="@+id/btn_vm_inline_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_inline_success" />

        <Button
            android:id="@+id/btn_vm_inline_fail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_inline_fail" />

        <Button
            android:id="@+id/btn_vm_page_loading_hide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_page_loading_hide" />

        <Button
            android:id="@+id/btn_vm_page_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_page_empty" />

        <Button
            android:id="@+id/btn_vm_page_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_page_error" />

        <Button
            android:id="@+id/btn_vm_page_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_page_success" />

        <Button
            android:id="@+id/btn_vm_page_empty_async"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_page_empty_async" />

        <Button
            android:id="@+id/btn_vm_page_error_async"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sandbox_vm_test_btn_page_error_async" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sandbox_vm_test_retry_tip"
            android:textAppearance="?attr/textAppearanceBodySmall" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/sandbox_vm_test_section_status"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/text_vm_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#FFF3F4F6"
            android:padding="12dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>
</ScrollView>
