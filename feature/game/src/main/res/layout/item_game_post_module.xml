<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="item"
            type="com.example.myapplication.game.adapter.GamePostRowModel" />
    </data>

    <!-- 宫格双列需固定卡片高度，避免文案行数不同导致上下不对齐（高度按满配：118 封面 + 2 行标题 + 3 行摘要估算） -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="256dp"
        android:layout_marginVertical="4dp"
        app:bl_corners_radius="12dp"
        app:bl_shape="rectangle"
        app:bl_solid_color="?attr/colorSurfaceContainerLow"
        app:bl_stroke_color="?attr/colorOutlineVariant"
        app:bl_stroke_width="1dp"
        tools:ignore="MissingPrefix">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/cover"
                android:layout_width="match_parent"
                android:layout_height="118dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:gravity="top"
                android:maxLines="2"
                android:text="@{item.title}"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                tools:text="标题示例" />

            <TextView
                android:id="@+id/body_preview"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="top"
                android:maxLines="3"
                android:text="@{item.bodyPreview}"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="摘要预览…" />
        </LinearLayout>
    </FrameLayout>
</layout>
